@baseUrl = https://localhost/api
### =========================
### AUTH
### =========================

### Registrar usuário
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "João Teste",
  "email": "joao@test.com",
  "password": "123456",
  "cpf": "893.942.440-93",
  "type": "driver"
}

###

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "joao@test.com",
  "password": "123456"
}

###

